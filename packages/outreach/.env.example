# Connection configuration for sending emails (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use an App Password (not your primary password) for security
SMTP_PASSWORD=your_gmail_app_password

# Connection configuration for drafting emails (IMAP)
# Note: By default, if IMAP_USER and IMAP_PASSWORD are not specified,
# the app will reuse SMTP_USER and SMTP_PASSWORD.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Sender identity
SENDER_NAME=Aditya Rane

# Safety & execution mode
# DRY_RUN=true: Only simulates actions and prints to the terminal.
# DRY_RUN=false: Will actually send emails or create drafts in Gmail.
DRY_RUN=true

# Groq API Key for LLM-powered personalization/rewriting.
# If left blank, the app will fall back to the deterministic templates.
GROQ_API_KEY=
# Groq model to use (e.g. llama-3.3-70b-versatile, llama3-8b-8192)
GROQ_MODEL=llama-3.3-70b-versatile
