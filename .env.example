# ==============================================================================
# UNIFIED CAREER AGENT PLATFORM — ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to `.env` in the required package folders, or set these 
# variables in your shell environment.
# ==============================================================================

# ─── FastAPI Sidecar Backend (apps/server/.env) ──────────────────────────────
# Encryption key used to secure candidate SMTP/IMAP passwords (AES-GCM-256)
ENCRYPTION_SECRET=your_super_secret_aes_key_here

# ─── Next.js Web Frontend (apps/web/.env.local) ────────────────────────────────
# Groq LLM API Key (Required for ATS Scoring & resume bullet optimizing)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Next.js Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend Sidecar API Gateway URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ─── Discovery Engine Scrapers (packages/scrapers/.env) ───────────────────────
# Firecrawl API Key (Required for Wellfound scraping)
# Get yours at https://www.firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ─── Outreach Console (packages/outreach/.env) ─────────────────────────────────
# Candidate SMTP & IMAP Configuration (for dry runs and fallback appends)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Safety Mode (set to "false" to execute real SMTP dispatches or save real IMAP drafts)
DRY_RUN=true
SENDER_NAME=Your Name
