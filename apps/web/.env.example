# =============================================================
# Resume Shapeshifter — Environment Template
# =============================================================
# Copy this file to .env.local and fill in your real values.
# This file IS committed to git (no secrets here — only keys).
# =============================================================

# ─── Groq LLM (REQUIRED) ─────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=

# Model to use
LLM_MODEL=llama-3.3-70b-versatile

# ─── App URL ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Puppeteer (optional) ────────────────────────────────────
# Uncomment and set if auto-detection fails on your machine:
# PUPPETEER_EXECUTABLE_PATH=
